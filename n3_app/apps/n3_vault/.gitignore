# ENV & SECRETS
# ==========================================
.env
config.py
secrets/

# ==========================================
# DATA PIPELINE / ETL WORKSPACE
# ==========================================
# Hide raw LLM audit logs and intermediate "dirty" data
data_pipeline/logs/
data_pipeline/temp/
migrate_working_dir/