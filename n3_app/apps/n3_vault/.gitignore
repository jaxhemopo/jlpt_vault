# ==========================================
# COMMERCIAL DATA PROTECTION (Proprietary)
# ==========================================
# Protect the 4,750+ parsed items and SQLite logic
*.csv
*.json
*.db
*.sqlite
*.sql
!data_pipeline/postgres_schema.sql  # Keep the schema, hide the data
!data_pipeline/sample_data.csv      # Allow a 3-row sample for recruiters

